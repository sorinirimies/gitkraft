pkgbase = gitkraft
	pkgdesc = Git IDE written entirely in Rust — desktop GUI and terminal UI
	pkgver = 0.7.7
	pkgrel = 1
	url = https://github.com/sorinirimies/gitkraft
	arch = x86_64
	arch = aarch64
	license = MIT
	makedepends = rust
	makedepends = cargo
	makedepends = cmake
	makedepends = pkg-config
